generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organizador {
  id        String   @id @default(uuid())
  nome      String
  email     String
  senha     String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  eventos   Evento[]

  @@map("organizadores")
}

model Evento {
  id          String   @id @default(uuid())
  data        String
  horario     String
  local     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  organizador_id String

  organizador Organizador @relation(fields: [organizador_id], references: [id])

  @@map("eventos")
}

model Atividade {
  id        String   @id @default(uuid())
  local     String
  horario   String
  descricao String
  vagas     Int
  banner    String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  inscricoes Inscricao[]

  @@map("atividades")
}

model Participante {
  id         String      @id @default(uuid())
  nome       String
  email      String
  senha      String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @default(now())

  inscricoes Inscricao[]

  @@map("participantes")
}

model Inscricao {
  id             String   @id @default(uuid())
  dataInscricao  String
  status         Boolean
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now())
  atividadeId    String
  participanteId String

  atividade    Atividade    @relation(fields: [atividadeId], references: [id])
  participante Participante @relation(fields: [participanteId], references: [id])

  @@map("inscricoes")
}
