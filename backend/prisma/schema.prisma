generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organizador {
  id        String   @id @default(uuid())
  nome      String
  email     String
  senha     String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  eventos   Evento[]

  @@map("organizadores")
}

model Evento {
  id             String      @id @default(uuid())
  nome           String
  data           String
  horario        String
  local          String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @default(now())
  organizador_id String
  atividades     Atividade[]
  organizador    Organizador @relation(fields: [organizador_id], references: [id])

  @@map("eventos")
}

model Atividade {
  id        String   @id @default(uuid())
  local     String
  horario   String
  descricao String
  vagas     String
  banner    String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  evento_id String

  inscricoes Inscricao[]
  Evento     Evento?     @relation(fields: [evento_id], references: [id])

  @@map("atividades")
}

model Participante {
  id        String   @id @default(uuid())
  nome      String
  email     String
  senha     String
  sexo      String
  idade     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  inscricoes Inscricao[]

  @@map("participantes")
}

model Inscricao {
  id              String   @id @default(uuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())
  atividade_id    String
  participante_id String

  atividade    Atividade    @relation(fields: [atividade_id], references: [id])
  participante Participante @relation(fields: [participante_id], references: [id])

  @@map("inscricoes")
}
