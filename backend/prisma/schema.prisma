generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organizador {
  id        String   @id @default(uuid())
  nome      String
  email     String
  senha     String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  eventos   Evento[]

  @@map("organizadores")
}

model Evento {
  id          String   @id @default(uuid())
  data        DateTime
  horario     DateTime
  localizacao String
  descricao   String
  vagas       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  organizador Organizador @relation(fields: [id], references: [id])
  inscricoes  Inscricao[]

  @@map("eventos")
}

model Participante {
  id         String      @id @default(uuid())
  nome       String
  email      String
  senha      String
  inscricoes Inscricao[]

  @@map("participantes")
}

model Inscricao {
  id             String       @id @default(uuid())
  dataInscricao  DateTime
  status         Boolean
  updatedAt      DateTime     @default(now())
  eventoId       String
  participanteId String
  evento         Evento       @relation(fields: [eventoId], references: [id])
  participante   Participante @relation(fields: [participanteId], references: [id])

  @@map("inscricoes")
}
